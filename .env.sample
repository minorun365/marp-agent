# ローカル開発時は認証スキップ
VITE_USE_MOCK=false

# Cognito User Migration Trigger使用時のみtrue（通常環境はfalse）
VITE_USE_USER_PASSWORD_AUTH=false

# Tavily APIキー（カンマ区切りで複数キー対応、レートリミット時に自動フォールバック）
TAVILY_API_KEYS=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx,tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx,tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# テストユーザー（sandbox環境で自動作成）
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=TestPass123!

# 既存Cognitoユーザープールから別環境へ自動移行する場合のみ設定
# 未設定の場合、User Migration Triggerは作成されない
OLD_USER_POOL_ID=
OLD_USER_POOL_CLIENT_ID=
OLD_ACCOUNT_ROLE_ARN=

# 共有スライドの独自ドメインを使う場合のみ両方設定
# ACM証明書はCloudFront用にus-east-1で発行する
SHARED_SLIDES_PUBLIC_DOMAIN=
SHARED_SLIDES_CERTIFICATE_ARN=

# 任意: デプロイ先ごとのタグ・Runtime名衝突回避
PROJECT_TAG_VALUE=
AGENT_RUNTIME_PREFIX=
